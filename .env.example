# Copy to .env for local development (never commit .env).

# Kafka
SERVICE_NAME=smart-shopper
ENVIRONMENT=local
LOG_LEVEL=INFO
METRICS_HOST=0.0.0.0
METRICS_PORT=8000
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=smart-shopper-dev
KAFKA_DEAD_LETTER_ENABLED=true
ORCHESTRATOR_GROUP_ID=orchestrator-agent
DECISION_GROUP_ID=decision-agent
SCRAPER_GROUP_ID=webscraping-agent
GENERATOR_GROUP_ID=agent-generator
GATEWAY_GROUP_ID=telegram-gateway
AMBIENT_GROUP_ID=ambient-scheduler
GOVERNANCE_GROUP_ID=governance-agent
DECISION_BATCH_WAIT_SECONDS=8

# Redis (global + per-user hot tier)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=1800

# MongoDB (per-user cold + private agent stores)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=smart_shopper
MONGO_CONNECT_TIMEOUT_MS=1000

# NER model service (gRPC / REST behind gateway or direct)
NER_GRPC_HOST=localhost
NER_GRPC_PORT=50051
NER_GRPC_TIMEOUT_SECONDS=30.0
NER_WARMUP_TEXT=Bghit Samsung phone b 3000 dh

# NER backend modes: auto, hf
# auto = download/use cached HF model; hf = same model path and fail loudly on load errors
SMART_SHOPPER_NER_BACKEND=auto
SMART_SHOPPER_NER_MODEL=ElAtrachAMINE/darija-ner-xlmroberta
SMART_SHOPPER_VOCAB_PATH=models/ner/resources/product_vocabulary.csv

# Hugging Face cache: keep model files local so Docker/AWS containers do not redownload every start
HF_HOME=.cache/huggingface
TOKENIZERS_PARALLELISM=false

# LLM provider (Agent Generator)
# Production MVP recommendation:
#   LLM_PROVIDER=groq
#   LLM_MODEL=llama-3.1-8b-instant
#   LLM_HTTP_BASE_URL=https://api.groq.com/openai/v1
# Keep real API keys in local .env, Docker secrets, AWS Secrets Manager, or Kubernetes secrets.
# Never commit real keys to git.
# Supported providers: template, groq, openai, openai-compatible, gemini
LLM_PROVIDER=template
LLM_API_KEY=
LLM_MODEL=llama-3.1-8b-instant
LLM_HTTP_BASE_URL=http://localhost:8081
LLM_TIMEOUT_SECONDS=10.0

# Optional provider examples. Uncomment one set locally if needed.
# Groq:
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-8b-instant
# LLM_HTTP_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=your_groq_api_key_here
# OpenAI:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4.1-mini
# LLM_HTTP_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_openai_api_key_here
# Gemini:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-flash
# LLM_HTTP_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# LLM_API_KEY=your_gemini_api_key_here

# Scraping / governance
SCRAPE_TIMEOUT_SECONDS=40
# Max parallel scrapes per task (routed lists are <=8 sites; 8 at a time)
SCRAPE_MAX_CONCURRENCY=8
# Extra seconds after per-site timeout before cancelling slow providers (~68-72s replies)
SCRAPE_COLLECTION_GRACE_SECONDS=10
# Route each query to relevant providers only (~80s quality budget)
SCRAPE_ROUTE_PROVIDERS=true
# Use the project LLM (LLM_PROVIDER / LLM_API_KEY) to pick the provider category
SCRAPE_ROUTE_USE_LLM=false
# Providers rendered with Playwright directly. Others use httpx only.
SCRAPE_PLAYWRIGHT_PROVIDERS=avito,biougnach,defacto,electroplanet,ikea,jumia,marjane,palmarosa
# Optional local test override only. Leave false for real scraping in compose/prod.
SCRAPE_MOCK_ONLY=false
DOMAIN_RATE_LIMIT_PER_MINUTE=30
USER_RATE_LIMIT_PER_MINUTE=20
GOVERNANCE_STRICT_ROBOTS=false
GOVERNANCE_QUARANTINE_PII=true
GOVERNANCE_CONTENT_MODERATION_ENABLED=true

# Telegram User-Proxy Gateway
TELEGRAM_BOT_TOKEN=

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
